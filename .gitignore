# 🛡️ NEA - Security & Environment Exclusions
# ============================================

# ─── SECRETS (NEVER PUSH THESE) ────────────────────────────────────────
**/.env
**/.env.local
**/.env.*.local
**/*.json
!**/package.json
!**/tsconfig.json
!**/manifest.json
!**/locales/*.json
!app/backend/pyproject.toml

# Specific Firebase Secret
app/backend/serviceAccountKey.json

# ─── DEPENDENCIES ─────────────────────────────────────────────────────
node_modules/
**/node_modules/
app/backend/.venv/
venv/
env/
.env/

# ─── DATABASE ──────────────────────────────────────────────────────────
# (Legacy SQLite exclusions kept for safety)
*.db
*.sqlite3
**/*.db
**/*.sqlite3

# ─── PYTHON CACHE ──────────────────────────────────────────────────────
__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.coverage
htmlcov/

# ─── FRONTEND BUILD & CACHE ────────────────────────────────────────────
dist/
build/
.vite/
.vitest_cache/
.eslintcache

# ─── SYSTEM & IDE ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.log
