# 🔑 Backend Environment Template
# Copy this to .env and fill in your actual credentials

# Google Cloud - Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK (Cloud-Native Firestore)
# Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# Firebase Web API Key (For verification if needed)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# Security & CORS
# Whitelist for frontend URLs (Localhost, Netlify, Render)
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.netlify.app

# CLI / Testing
CLI_SERVER_URL=http://127.0.0.1:8000

# Performance (Optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL=86400
