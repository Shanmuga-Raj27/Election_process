GEMINI_API_KEY=your_gemini_api_key_here
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
DATABASE_URL=sqlite:///./election_chatbot.db
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.netlify.app
CLI_SERVER_URL=https://your-api-url.com
# Use http://127.0.0.1:8000 for local testing
# TESTING=1  # Uncomment for test mode (uses in-memory DB)
# Redis Caching (Optional - app works without it)
REDIS_URL=redis://localhost:6379
CACHE_TTL=86400
